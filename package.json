{
  "name": "monityio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev": "concurrently --kill-others -n \"client,server\" -c \"cyan,magenta\" \"npm run dev:client\" \"npm run dev:server\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js --update-env",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "pm2": "^5.4.3"
  }
}
